{
  "name": "gaiamod-desktop",
  "productName": "GaiaMod Desktop",
  "version": "1.0.0",
  "description": "Desktop version of GaiaMod (without portalix launcher).",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1",
    "load:gui": "node guiProcess.js",
    "load:packager": "node packagerProcess.js"
  },
  "keywords": [
    "gaiamod",
    "desktop"
  ],
  "author": "Aness6040",
  "license": "MIT",
  "build": {
    "appId": "com.portalix.gaiamod-desktop",
    "linux": {
      "target": [
        "snap",
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "win": {
      "icon": "assets/icon/icon.ico"
    },
    "mac": {
      "icon": "assets/icon/icon.icns"
    }
  },   
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "discord-rpc": "^4.0.1",
    "lodash": "^4.17.21"
  }
}
